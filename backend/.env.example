# Database Configuration
# Para PostgreSQL local:
DATABASE_URL="postgresql://user:password@localhost:5432/financeflow?schema=public"

# Para NeonDB (recomendado para desenvolvimento):
# DATABASE_URL="postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/neondb?sslmode=require"

# JWT Configuration
# IMPORTANTE: Altere este valor para um secret seguro em produção!
# Use: openssl rand -base64 32 para gerar um secret seguro
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"

# Server Configuration
PORT=3000
FRONTEND_URL="http://localhost:5173"

# Environment
NODE_ENV="development"
