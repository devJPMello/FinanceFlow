# Database
DATABASE_URL="postgresql://user:password@localhost:5432/financeflow?schema=public"

# Clerk (Dashboard → Configure → API Keys → Secret key)
CLERK_SECRET_KEY="sk_test_..."

PORT=3000
# Produção: URL do front (Render static). Vários origins: separar por vírgula.
FRONTEND_URL="http://localhost:5173"
NODE_ENV="development"

# Produção: validação na arranque (DATABASE_URL + CLERK_SECRET_KEY obrigatórios)
# Swagger em /api/docs fica DESLIGADO em produção salvo:
# ENABLE_SWAGGER_IN_PROD="true"
#
# POST /api/feature-flags/:key (admin) exige header:
#   x-admin-operations-secret: <mesmo valor que>
# ADMIN_OPERATIONS_SECRET="gere-um-segredo-longo-aleatorio"

# Google AI Studio / Gemini (comentários IA + importação de extrato PDF em Transações)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# Opcional; padrão: gemini-2.5-flash
# GEMINI_MODEL="gemini-2.5-flash"

# Observabilidade (opcional)
# SENTRY_DSN="https://...@sentry.io/..."

# Limites de upload (bytes; opcional — há valores por defeito no código)
# IMPORT_MAX_FILE_BYTES=15728640
# ATTACHMENT_MAX_FILE_BYTES=10485760
# ASYNC_JOB_PDF_MAX_BYTES=12582912

# Segurança de anexos
# ATTACHMENT_URL_SECRET="troque-este-segredo"
# ATTACHMENT_SCAN_ENABLED="false"

# Custos e quotas IA (por utilizador; importação PDF/CSV/imagem e OCR TaxVision contam)
# AI_DAILY_LIMIT_PER_USER="60"
# AI_BURST_PER_MINUTE_PER_ROUTE="12"

# Fila assíncrona: na API use true para não competir com o processo worker (npm run start:worker)
# DISABLE_JOB_POLLER="false"

# Deploy / probes (HTTP)
# Liveness:  GET /api/health/live  — processo OK
# Readiness: GET /api/health/ready — 503 se PostgreSQL não responder
# Fila worker: GET /api/health/jobs — contagens async_jobs, falhas na última hora, poller desativado?
#
# Backup automatizado (produção)
#   npm run db:backup  (ou: node scripts/backup-db.mjs)
#   BACKUP_RETENTION_COUNT=14 — após cada dump, apaga ficheiros .sql antigos em ./backups
#   Linux/macOS: scripts/schedule-daily-backup.sh · Windows: scripts/schedule-daily-backup.ps1
#   GitHub: workflow db-backup-dispatch.yml (workflow_dispatch + secret DATABASE_URL)
#
# Rotação de segredos (checklist)
#   Clerk: rodar secret key no dashboard; atualizar CLERK_SECRET_KEY e publishable no front.
#   DATABASE_URL: alterar password na BD e no .env; reiniciar API e workers.
#   GEMINI_API_KEY / SENTRY_DSN / ATTACHMENT_URL_SECRET: gerar novo, deploy, revogar antigo.
